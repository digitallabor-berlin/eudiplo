# =============================================================================
# EUDIPLO - k6 Load Test Configuration
# =============================================================================
# Used by scripts/load-test/run-all.sh to start deployment/docker-compose
# with a predictable config for load testing.
#
# Run manually:
#   docker compose --env-file k6.env --profile standard up -d
# =============================================================================

# Public URL used by backend metadata and redirects
PUBLIC_URL=http://localhost:3000

# Use this same file as the container env_file source
EUDIPLO_ENV_FILE=k6.env

# Mount repository assets into /app/config so config import can read
# assets/config/demo/{issuance,presentation,...}
EUDIPLO_CONFIG_MOUNT=../../assets/config:/app/config
CONFIG_FOLDER=/app/config

# Authentication used by load test scripts
MASTER_SECRET=k6-load-test-secret-minimum-32-characters
AUTH_CLIENT_ID=admin
AUTH_CLIENT_SECRET=admin

# Enable startup import from mounted assets/config
CONFIG_IMPORT=true
CONFIG_IMPORT_FORCE=true

# Logging
LOG_LEVEL=info
LOG_ENABLE_SESSION_LOGGER=false
LOG_SESSION_STORE=off
LOG_ENABLE_HTTP_LOGGER=false

# Database: PostgreSQL (provided by compose standard profile)
# NOTE: This password is only valid for a freshly initialised Postgres volume.
#       If you reuse an existing volume that was initialised with a different
#       DB_PASSWORD, start with a clean state first:
#         docker compose --env-file k6.env --profile standard down -v
#         docker compose --env-file k6.env --profile standard up -d
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=eudiplo
DB_PASSWORD=eudiplo
DB_DATABASE=eudiplo

# Key management + storage
KM_TYPE=db
STORAGE_DRIVER=s3
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=uploads
S3_FORCE_PATH_STYLE=true

# MinIO container settings
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
