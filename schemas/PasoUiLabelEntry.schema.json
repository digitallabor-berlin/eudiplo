{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/openwallet-foundation/eudiplo/refs/heads/main/schemas/PasoUiLabelEntry.schema.json",
  "title": "PasoUiLabelEntry",
  "type": "object",
  "properties": {
    "locale": {
      "type": "string",
      "description": "Locale code (e.g., 'en')",
      "example": "en"
    },
    "value": {
      "type": "string",
      "description": "The text value of the UI label",
      "example": "Do you want to authorize this payment?"
    },
    "value_type": {
      "type": "string",
      "description": "Optional value type designation",
      "example": "text/markdown"
    }
  },
  "required": [
    "value"
  ],
  "additionalProperties": false
}