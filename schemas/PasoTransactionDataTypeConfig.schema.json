{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/openwallet-foundation/eudiplo/refs/heads/main/schemas/PasoTransactionDataTypeConfig.schema.json",
  "title": "PasoTransactionDataTypeConfig",
  "type": "object",
  "properties": {
    "claims": {
      "description": "Claims included in this transaction data type",
      "type": "array",
      "items": {
        "$ref": "./PasoClaimMetadata.schema.json"
      }
    },
    "ui_labels": {
      "description": "UI labels for the transaction UI",
      "allOf": [
        {
          "$ref": "./PasoUiLabels.schema.json"
        }
      ]
    }
  },
  "required": [
    "claims"
  ],
  "additionalProperties": false
}