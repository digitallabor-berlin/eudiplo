{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/openwallet-foundation/eudiplo/refs/heads/main/schemas/FieldDisplayDto.schema.json",
  "title": "FieldDisplayDto",
  "type": "object",
  "properties": {
    "locale": {
      "type": "string",
      "description": "Locale code based on BCP47 (RFC 5646)",
      "example": "en-US"
    },
    "name": {
      "type": "string",
      "description": "Display name",
      "example": "Given Name"
    },
    "description": {
      "type": "string",
      "description": "Optional display description",
      "example": "Primary first name"
    }
  },
  "required": [
    "locale",
    "name"
  ],
  "additionalProperties": false
}