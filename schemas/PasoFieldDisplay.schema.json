{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/openwallet-foundation/eudiplo/refs/heads/main/schemas/PasoFieldDisplay.schema.json",
  "title": "PasoFieldDisplay",
  "type": "object",
  "properties": {
    "locale": {
      "type": "string",
      "description": "Locale code (e.g., 'en', 'de')",
      "example": "en"
    },
    "name": {
      "type": "string",
      "description": "Display name for the field",
      "example": "Amount"
    },
    "display_type": {
      "type": "string",
      "description": "Optional display type",
      "example": "amount"
    }
  },
  "required": [
    "locale",
    "name"
  ],
  "additionalProperties": false
}